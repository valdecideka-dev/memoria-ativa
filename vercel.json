{
  "buildCommand": "npm install",
  "outputDirectory": "public",
  "env": {
    "SUPABASE_URL": "@SUPABASE_URL",
    "SUPABASE_ANON_KEY": "@SUPABASE_ANON_KEY",
    "GEMINI_API_KEY": "@GEMINI_API_KEY",
    "GEMINI_MODEL": "@GEMINI_MODEL"
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    }
  ]
}

# ============================================================
# Copie este arquivo e renomeie a cópia para ".env" (para testar
# no seu computador) — NUNCA envie o arquivo ".env" para o GitHub.
#
# Na Vercel (hospedagem), essas mesmas chaves são coladas na
# aba "Environment Variables" do projeto (veja o README.md, passo 5).
# ============================================================

# Chave secreta da IA do Google (Gemini). Como conseguir: README.md, passo 3.
GEMINI_API_KEY=cole_aqui_sua_chave_do_google_ai_studio

# (Opcional) Nome do modelo gratuito do Gemini. Pode deixar como está.
GEMINI_MODEL=gemini-2.5-flash
